{%- liquid
  assign icon_name = icon | default: 'sparkle'
-%}

{%- case icon_name -%}
  {%- when 'truck' -%}
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true" focusable="false"><path d="M3 7h14v11H3V7Zm14 4h4l4 4v3h-8v-7Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M8 22a2 2 0 1 0 0-4 2 2 0 0 0 0 4Zm13 0a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z" stroke="currentColor" stroke-width="1.6"/></svg>
  {%- when 'users' -%}
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true" focusable="false"><path d="M11 14a4 4 0 1 0 0-8 4 4 0 0 0 0 8Zm-7 8c.7-3.5 3.4-6 7-6s6.3 2.5 7 6" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/><path d="M18 14a3.2 3.2 0 0 0 0-6.2M20 17c2.2.7 3.6 2.4 4 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
  {%- when 'shield' -%}
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true" focusable="false"><path d="M14 3 5 7v7c0 5.2 3.8 8.9 9 11 5.2-2.1 9-5.8 9-11V7l-9-4Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="m10 14 2.5 2.5L18.5 10" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {%- when 'return' -%}
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true" focusable="false"><path d="M9 9 5 13l4 4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/><path d="M5 13h11a6 6 0 1 1-4.3 10.2" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
  {%- when 'diamond' -%}
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true" focusable="false"><path d="M8 4h12l5 7-11 13L3 11l5-7Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M3 11h22M9 4l5 20 5-20" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/></svg>
  {%- when 'ring' -%}
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true" focusable="false"><path d="M10 8h8l-4 5-4-5Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M14 13a6 6 0 1 1-5.2 3" stroke="currentColor" stroke-width="1.6" stroke-linecap="round"/></svg>
  {%- when 'mail' -%}
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true" focusable="false"><path d="M4 7h20v14H4V7Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="m5 8 9 8 9-8" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/></svg>
  {%- when 'star' -%}
    <svg width="28" height="28" viewBox="0 0 28 28" fill="currentColor" aria-hidden="true" focusable="false"><path d="m14 3 3.2 7 7.6.9-5.6 5.1 1.5 7.5L14 19.7l-6.7 3.8L8.8 16l-5.6-5.1 7.6-.9L14 3Z"/></svg>
  {%- else -%}
    <svg width="28" height="28" viewBox="0 0 28 28" fill="none" aria-hidden="true" focusable="false"><path d="M14 3c.8 5.3 3.7 8.2 9 9-5.3.8-8.2 3.7-9 9-.8-5.3-3.7-8.2-9-9 5.3-.8 8.2-3.7 9-9Z" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round"/><path d="M22 2c.3 2 1.4 3.1 3 3.5-1.6.4-2.7 1.5-3 3.5-.4-2-1.5-3.1-3-3.5 1.5-.4 2.6-1.5 3-3.5Z" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/></svg>
{%- endcase -%}
